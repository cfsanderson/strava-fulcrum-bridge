# Example .env file for Strava → Fulcrum Webhook Bridge
# Copy to .env and fill in your real values

STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
FULCRUM_API_TOKEN=your_fulcrum_api_token

# Original Fulcrum Form ID
FULCRUM_FORM_ID=your_fulcrum_form_id

# OPTIONAL: Enhanced v2 Form ID (for dual form submission)
# Allows submitting activity data to a second form simultaneously
# FULCRUM_FORM_ID_V2=your_enhanced_v2_form_id

# OPTIONAL: Enable submitting to both forms simultaneously
# Requires FULCRUM_FORM_ID_V2 to be set
# ENABLE_DUAL_FORM=true

# CALLBACK_URL is only needed for strava-auth.sh if registering webhooks manually
CALLBACK_URL=https://your-app-url/strava-webhook
